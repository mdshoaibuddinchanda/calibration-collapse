# =============================================================================
# Calibration Collapse — .gitignore
# Generated outputs are excluded. Folder structure is preserved via .gitkeep.
# Run the project to regenerate all outputs.
# =============================================================================

# ── Generated outputs (all regenerated by running experiments) ───────────────
outputs/
!outputs/.gitkeep
!outputs/metrics/.gitkeep
!outputs/metrics/calibration/.gitkeep
!outputs/metrics/classification/.gitkeep
!outputs/plots/.gitkeep
!outputs/plots/reliability/.gitkeep
!outputs/plots/confidence_hist/.gitkeep
!outputs/plots/frontier/.gitkeep
!outputs/plots/uncertainty/.gitkeep
!outputs/logs/.gitkeep
!outputs/multiseed/.gitkeep

# ── Experiment database (use JSON manifests for reproducibility) ─────────────
outputs/experiments.db

# ── Artifacts (trained models, fitted scalers) ───────────────────────────────
artifacts/
!artifacts/.gitkeep
!artifacts/models/.gitkeep
!artifacts/preprocessed/.gitkeep

# ── Reports (generated summaries and ablation CSVs) ──────────────────────────
reports/summaries/
reports/ablations/
!reports/.gitkeep
!reports/summaries/.gitkeep
!reports/ablations/.gitkeep
# Keep math docs (hand-written, not generated)
!reports/math/

# ── Raw datasets (too large for git; download via scripts/_download_datasets.py)
datasets/raw/
!datasets/raw/.gitkeep
# Synthetic datasets (regenerated via scripts/_generate_synthetic.py)
datasets/synthetic/
!datasets/synthetic/.gitkeep

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
.eggs/
dist/
build/
*.whl

# ── Virtual environments ──────────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/

# ── IDE and editor files ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# ── OS generated files ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── pytest cache ─────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Paper output — script + all generated figures/tables are committed
# Figures and tables are included so reviewers can see results without running code
# paper_output/ is fully tracked (nothing excluded)

# ── Temporary and scratch files ───────────────────────────────────────────────
*.tmp
*.bak
*.orig
scratch/
tmp/
